@{
    Layout = "~/Views/Shared/_Layout.cshtml"; // Using main app layout
}

<div class="container">
    <h1>Help Section</h1>

    <nav class="mt-5">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Home" && ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")" href="@Url.Action("Index", "Home", new { Area = "Help" })">Home</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Tutorial" && ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")" href="@Url.Action("Index", "Tutorial", new { id = "Page1", Area = "Help" })">Tutorial</a>
            </li>
        </ul>
    </nav>

    <div class="mt-3">
        @RenderBody() <!-- Render the view's content -->
    </div>
</div>
