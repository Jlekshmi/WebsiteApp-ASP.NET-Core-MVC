<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="index-page">
    <header id="header" class="header d-flex align-items-center fixed-top">
        <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

            <a href="index.html" class="logo d-flex align-items-center">
                <h1 class="sitename">My Website</h1>
            </a>
        
            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a class="nav-link" asp-controller="Home" asp-action="Index" asp-area="">Home</a></li>
                    <li><a class="nav-link" asp-controller="Home" asp-action="About" asp-area="">About</a></li>
                    <li><a class="nav-link" asp-controller="Home" asp-action="Contact" asp-area="">Contact</a></li>
                    <li><a class="nav-link" asp-area="Help" asp-controller="Home" asp-action="Index">Help</a></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>

        </div>
    </header>
        <section id="hero" class="hero section dark-background">
            <img src="img\hero-bg-2.jpg" alt="" class="hero-bg">

            <div class="container">
                <div class="row gy-4 justify-content-between">


                    <div class="col-lg-12 text-center  d-flex flex-column justify-content-center" data-aos="fade-in">
                        <h1> <span>@ViewData["Title"]</span></h1>
                    </div>

                </div>
            </div>

            <svg class="hero-waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28 " preserveAspectRatio="none">
                <defs>
                    <path id="wave-path" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"></path>
                </defs>
                <g class="wave1">
                    <use xlink:href="#wave-path" x="50" y="3"></use>
                </g>
                <g class="wave2">
                    <use xlink:href="#wave-path" x="50" y="0"></use>
                </g>
                <g class="wave3">
                    <use xlink:href="#wave-path" x="50" y="9"></use>
                </g>
            </svg>

        </section><!-- /Hero Section -->
    <div class="container mt-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer id="footer" class="footer">
        <div class="container copyright text-center mt-4">
            <p>&copy; Copyright - Jayalekshmi Vrinda Kumari Jayachandran </p>
        </div>

    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
